# ── OrcAgent Environment Variables ──

# Flask secret key (change in production)
SECRET_KEY=change-me-in-production

# REQUIRED: Fernet key used to double-encrypt stored private keys.
# The app refuses to start without this. Generate one with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Store the generated value here (and in Railway Variables for production).
ENCRYPTION_KEY=

# Performance fee collection wallet — 5% of profitable trades are sent here
OWNER_WALLET=<your-owner-wallet-address>

# Anthropic API key — enables Claude Haiku AI signal boost (optional but recommended)
ANTHROPIC_API_KEY=

# Server-side fallback wallet (optional, only needed for legacy CLI mode)
WALLET_ADDRESS=

# Jupiter proxy (optional — set if Railway IPs are rate-limited by quote-api.jup.ag)
# Deploy proxy/worker.js to Cloudflare Workers (free), then paste the URL here.
# See proxy/wrangler.toml for step-by-step deploy instructions.
JUPITER_PROXY_URL=
JUPITER_PROXY_SECRET=

# Standalone trading script parameters (only used when running orcagent_solana.py directly)
WALLET_PRIVATE_KEY=
MAX_USDC=50
STOP_LOSS=0.05
TAKE_PROFIT=0.15
TRAILING_STOP=0.03
INTERVAL=60
