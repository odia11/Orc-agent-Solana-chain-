# ── OrcAgent Environment Variables ──

# Flask secret key (change in production)
SECRET_KEY=change-me-in-production

# REQUIRED: Fernet key used to double-encrypt stored private keys.
# The app refuses to start without this. Generate one with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Store the generated value here (and in Railway Variables for production).
ENCRYPTION_KEY=

# Performance fee collection wallet — 5% of profitable trades are sent here
OWNER_WALLET=<your-owner-wallet-address>

# Server-side fallback wallet (optional, only needed for legacy CLI mode)
WALLET_ADDRESS=

# Birdeye API key — used for OHLCV candle data in the token carousel chart.
# DexScreener's internal chart API is blocked for server-side requests (Cloudflare),
# so Birdeye is the primary candle source. Get a free key at birdeye.so.
BIRDEYE_API_KEY=

# Anthropic API key (used by orcagent_solana.py standalone mode)
ANTHROPIC_API_KEY=

# Standalone trading script parameters (only used when running orcagent_solana.py directly)
WALLET_PRIVATE_KEY=
MAX_USDC=50
STOP_LOSS=0.05
TAKE_PROFIT=0.15
TRAILING_STOP=0.03
INTERVAL=60
