# ── OrcAgent Environment Variables ──

# Flask secret key (change in production)
SECRET_KEY=change-me-in-production

# Optional: persistent Fernet encryption key for private keys stored in DB.
# If not set, a key is auto-generated and persisted in the SQLite DB.
ENCRYPTION_KEY=

# Performance fee collection wallet — 5% of profitable trades are sent here
OWNER_WALLET=57enjXJH7Ro1aVTT97NuSvf3noYEsBwp4GUjet22vGW6

# Server-side fallback wallet (optional, only needed for legacy CLI mode)
WALLET_ADDRESS=

# Anthropic API key (used by orcagent_solana.py standalone mode)
ANTHROPIC_API_KEY=

# Standalone trading script parameters (only used when running orcagent_solana.py directly)
WALLET_PRIVATE_KEY=
MAX_USDC=50
STOP_LOSS=0.05
TAKE_PROFIT=0.15
TRAILING_STOP=0.03
INTERVAL=60
