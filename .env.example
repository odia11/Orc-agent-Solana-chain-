# OrcAgent — environment variables
# Copy this file to .env and fill in your values

# Required: Anthropic API key (used by orcagent_solana.py for AI trade decisions)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: default wallet address for balance display (users connect their own via Phantom/Solflare)
WALLET_ADDRESS=

# Fernet encryption key for private key storage in SQLite
# Generate one with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# Flask session secret (any random string, keep secret in production)
SECRET_KEY=change-me-to-a-random-string

# Railway sets this automatically; set to 5000 for local dev
PORT=5000
